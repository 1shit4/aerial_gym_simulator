<?xml version="1.0"?>
<robot name="quadrotor_with_arm">

  <!-- ========================================== -->
  <!--           X500 DRONE DESCRIPTION           -->
  <!-- ========================================== -->

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.0"/>
      <geometry>
        <box size="0.4 0.4 0.025"/>
      </geometry>
      <material name="White">
        <color rgba="1 1 1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.4 0.4 0.025"/>
      </geometry>
    </collision>
    <inertial>
      <!-- Origin defaults to 0 0 0, which is the COM -->
      <mass value="1.4"/>
      <inertia ixx="0.0139" ixy="0.0" ixz="0.0" iyy="0.0139" iyz="0.0" izz="0.0246"/>
    </inertial>
  </link>

  <link name="front_right_prop">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.07"/>
      </geometry>
      <material name="Orange">
        <color rgba="1.0 0.423 0.03921568627 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.064"/>
      <inertia ixx="0.000001" ixy="0.0" ixz="0.0" iyy="0.000001" iyz="0.0" izz="0.000001"/>
    </inertial>
  </link>

  <joint name="base_link_to_front_right_prop" type="fixed" dont_collapse="true">
    <parent link="base_link"/>
    <child link="front_right_prop"/>
    <origin xyz="0.174 -0.174 0"/>
  </joint>

  <link name="back_right_prop">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.07"/>
      </geometry>
      <material name="Blue">
        <color rgba="0 0 1 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.064"/>
      <inertia ixx="0.000001" ixy="0.0" ixz="0.0" iyy="0.000001" iyz="0.0" izz="0.000001"/>
    </inertial>
  </link>

  <joint name="base_link_to_back_right_prop" type="fixed" dont_collapse="true">
    <parent link="base_link"/>
    <child link="back_right_prop"/>
    <origin xyz="-0.174 -0.174 0"/>
  </joint>

  <link name="back_left_prop">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.07"/>
      </geometry>
      <material name="Blue">
        <color rgba="0 0 1 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.064"/>
      <inertia ixx="0.000001" ixy="0.0" ixz="0.0" iyy="0.000001" iyz="0.0" izz="0.000001"/>
    </inertial>
  </link>

  <joint name="base_link_to_back_left_prop" type="fixed" dont_collapse="true">
    <parent link="base_link"/>
    <child link="back_left_prop"/>
    <origin xyz="-0.174 0.174 0"/>
  </joint>

  <link name="front_left_prop">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.07"/>
      </geometry>
      <material name="Orange">
        <color rgba="1 0.423 0.03921568627 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.064"/>
      <inertia ixx="0.000001" ixy="0.0" ixz="0.0" iyy="0.000001" iyz="0.0" izz="0.000001"/>
    </inertial>
  </link>

  <joint name="base_link_to_front_left_prop" type="fixed" dont_collapse="true">
    <parent link="base_link"/>
    <child link="front_left_prop"/>
    <origin xyz="0.174 0.174 0"/>
  </joint>

  <!-- ========================================== -->
  <!--           MOUNTING JOINT (12cm Down)       -->
  <!-- ========================================== -->

  <joint name="mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_base_link"/>
    <!-- 12 cm below the drone COM (which is at 0,0,0) -->
    <origin xyz="0 0 -0.12" rpy="0 0 0"/>
  </joint>

  <!-- ========================================== -->
  <!--           2-DOF ARM DESCRIPTION            -->
  <!-- ========================================== -->

  <!-- Renamed 'base_link' to 'arm_base_link' to avoid conflict -->
  <link name="arm_base_link">
    <inertial>
      <origin xyz="-0.019361 0.032893 -9.1547E-05" rpy="0 0 0" />
      <mass value="0.052444" />
      <inertia
        ixx="1.5785E-05" ixy="-2.5913E-07" ixz="-6.0461E-09"
        iyy="9.052E-06" iyz="-6.1966E-07" izz="1.5108E-05" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <cylinder length="0.04" radius="0.04"/>
      </geometry>
      <material name="arm_base_material">
        <color rgba="0.75 0.75 0.75 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <cylinder length="0.04" radius="0.04"/>
      </geometry>
    </collision>
  </link>

  <!-- Renamed 'link_1' to 'arm_link_1' -->
  <link name="arm_link_1">
    <inertial>
      <origin xyz="-0.023624 -1.3508E-07 -0.068962" rpy="0 0 0" />
      <mass value="0.037731" />
      <!--mass value="0.2"/-->
      <inertia
        ixx="1.7815E-05" ixy="-3.5965E-12" ixz="-1.8434E-07"
        iyy="2.7209E-05" iyz="-1.2773E-10" izz="1.2586E-05" />
      <!--inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" /-->
    </inertial>
    <visual>
      <origin xyz="0 0 -0.09" rpy="0 0 0" />
      <geometry>
        <cylinder length="0.18" radius="0.02"/>
      </geometry>
      <material name="link1_material">
        <color rgba="0.7 0.7 0.7 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.09" rpy="0 0 0" />
      <geometry>
        <cylinder length="0.18" radius="0.02"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_1" type="continuous">
    <origin xyz="0.00275 0.049125 0.001225" rpy="0 0 0" />
    <parent link="arm_base_link" />
    <child link="arm_link_1" />
    <axis xyz="-1 0 0" />
    <!-- Set actual limits and give the motor some "Effort" (Strength) -->
    <limit lower="-1.57" upper="1.57" effort="100" velocity="100" />
    <!--limit lower="0" upper="0" effort="0" velocity="0" /-->
  </joint>

  <!-- Renamed 'link_2' to 'arm_link_2' -->
  <link name="arm_link_2">
    <inertial>
      <origin xyz="-0.023061 0.00033471 -0.097629" rpy="0 0 0" />
      <mass value="0.21897" />
      <!--mass value="0.2"/-->
      <inertia
        ixx="0.00011176" ixy="-2.2612E-09" ixz="7.538E-07"
        iyy="0.00012426" iyz="1.022E-06" izz="5.0106E-05" />
        <!--inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" /-->    
    </inertial>
    <visual>
      <origin xyz="0 0 -0.1" rpy="0 0 0" />
      <geometry>
         <cylinder length="0.20" radius="0.02"/>
      </geometry>
      <material name="link2_material">
        <color rgba="0.7 0.7 0.7 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.1" rpy="0 0 0" />
      <geometry>
         <cylinder length="0.20" radius="0.02"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_2" type="continuous">
    <origin xyz="0.0019 0 -0.1795" rpy="-0.0018049 0 0" />
    <parent link="arm_link_1" />
    <child link="arm_link_2" />
    <axis xyz="-1 0 0" />
    <!-- Set actual limits and give the motor some "Effort" (Strength) -->
    <limit lower="-2.094" upper="2.094" effort="100" velocity="100" />
  </joint>

</robot>
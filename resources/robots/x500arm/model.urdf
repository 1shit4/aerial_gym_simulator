<?xml version="1.0"?>
<robot name="quadrotor_with_arm">

  <!-- ========================================== -->
  <!--           X500 DRONE DESCRIPTION           -->
  <!-- ========================================== -->

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.353 0.353 0.05"/>
      </geometry>
      <material name="White">
        <color rgba="1 1 1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <!-- <box size="0.353 0.353 0.05"/> -->
        <box size="1.0 1.0 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.02166666666666667" ixy="0.0" ixz="0.0" iyy="0.02166666666666667" iyz="0.0" izz="0.04000000000000001"/>
    </inertial>
  </link>

  <link name="front_right_prop">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.13" length="0.01"/>
      </geometry>
      <material name="Orange">
        <color rgba="1.0 0.423 0.03921568627 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.016076923076923075"/>
      <inertia ixx="3.8464910483993325e-07" ixy="0.0" ixz="0.0" iyy="2.6115851691700804e-05" iyz="0.0" izz="2.649858234714004e-05"/>
    </inertial>
  </link>
  <joint name="base_link_to_front_right_prop" type="fixed">
    <parent link="base_link"/>
    <child link="front_right_prop"/>
    <origin xyz="0.174 -0.174 0.06"/>
  </joint>

  <link name="back_right_prop">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.13" length="0.01"/>
      </geometry>
      <material name="Blue">
        <color rgba="0 0 1 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.016076923076923075"/>
      <inertia ixx="3.8464910483993325e-07" ixy="0.0" ixz="0.0" iyy="2.6115851691700804e-05" iyz="0.0" izz="2.649858234714004e-05"/>
    </inertial>
  </link>
  <joint name="base_link_to_back_right_prop" type="fixed">
    <parent link="base_link"/>
    <child link="back_right_prop"/>
    <origin xyz="-0.174 -0.174 0.06"/>
  </joint>

  <link name="back_left_prop">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.13" length="0.01"/>
      </geometry>
      <material name="Blue">
        <color rgba="0 0 1 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.016076923076923075"/>
      <inertia ixx="3.8464910483993325e-07" ixy="0.0" ixz="0.0" iyy="2.6115851691700804e-05" iyz="0.0" izz="2.649858234714004e-05"/>
    </inertial>
  </link>
  <joint name="base_link_to_back_left_prop" type="fixed">
    <parent link="base_link"/>
    <child link="back_left_prop"/>
    <origin xyz="-0.174 0.174 0.06"/>
  </joint>

  <link name="front_left_prop">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <cylinder radius="0.13" length="0.01"/>
      </geometry>
      <material name="Orange">
        <color rgba="1.0 0.423 0.03921568627 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.016076923076923075"/>
      <inertia ixx="3.8464910483993325e-07" ixy="0.0" ixz="0.0" iyy="2.6115851691700804e-05" iyz="0.0" izz="2.649858234714004e-05"/>
    </inertial>
  </link>
  <joint name="base_link_to_front_left_prop" type="fixed">
    <parent link="base_link"/>
    <child link="front_left_prop"/>
    <origin xyz="0.174 0.174 0.06"/>
  </joint>

  <!-- ========================================== -->
  <!--           ARM DESCRIPTION (SYNCED TO PX4)  -->
  <!-- ========================================== -->

  <!-- Joint arm_to_L1 (Fixed mount matching PX4) -->
  <joint name="arm_to_L1" type="fixed">
    <parent link="base_link"/>
    <child link="l1_link"/>
    <!-- Same relative offset as PX4 base_to_arm -->
    <origin xyz="0 0 -0.025" rpy="0 3.14159265 0"/>
  </joint>

  <link name="l1_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.052"/>
      <inertia ixx="0.0000157" ixy="0" ixz="0" iyy="0.000009" iyz="0" izz="0.0000151"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.019" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.038" radius="0.02"/>
      </geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.019" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.038" radius="0.02"/>
      </geometry>
    </collision>
  </link>

  <!-- Joint L1_to_L2 (1st DOF) -->
  <joint name="L1_to_L2" type="revolute">
    <parent link="l1_link"/>
    <child link="l2_link"/>
    <origin xyz="0 0 0.03796" rpy="0 1.57 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="0" effort="1000" velocity="0.5"/>
  </joint>

  <link name="l2_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.038"/>
      <inertia ixx="0.0000178" ixy="0" ixz="0" iyy="0.0000272" iyz="0" izz="0.0000125"/>
    </inertial>
    <visual>
      <!-- Centers simple cylinder halfway to L3 -->
      <origin xyz="0.015 0 0.118" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.236" radius="0.02"/>
      </geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <origin xyz="0.015 0 0.118" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.236" radius="0.02"/>
      </geometry>
    </collision>
  </link>

  <!-- Joint L2_to_L3 (2nd DOF) -->
  <joint name="L2_to_L3" type="revolute">
    <parent link="l2_link"/>
    <child link="l3_link"/>
    <origin xyz="0.03 0 0.23682" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="1000" velocity="0.5"/>
  </joint>

  <link name="l3_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.219"/>
      <inertia ixx="0.0001117" ixy="0" ixz="0" iyy="0.0001242" iyz="0" izz="0.0000501"/>
    </inertial>
    <visual>
      <!-- Centers simple cylinder halfway to L4 -->
      <origin xyz="0 0 0.108" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.216" radius="0.02"/>
      </geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.108" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.216" radius="0.02"/>
      </geometry>
    </collision>
  </link>

  <!-- Joint L3_to_L4 (3rd DOF - Twist Joint) -->
  <joint name="L3_to_L4" type="revolute">
    <parent link="l3_link"/>
    <child link="l4_link"/>
    <origin xyz="0 0 0.21599" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="1000" velocity="0.5"/>
  </joint>

  <link name="l4_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <!-- Box makes the Z-axis twist rotation visually obvious -->
      <geometry>
        <box size="0.02 0.06 0.04"/>
      </geometry>
      <material name="red"><color rgba="1 0 0 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.06 0.04"/>
      </geometry>
    </collision>
  </link>

</robot>